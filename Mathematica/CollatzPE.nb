              RowBox[{
               RowBox[{
                RowBox[{"Mod", "[", 
                 RowBox[{"nxt", ",", "2"}], "]"}], "==", "0"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"AppendTo", "[", 
