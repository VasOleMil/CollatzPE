              RowBox[{"(", 
               RowBox[{"i", "-", "1"}], ")"}], "/", "Pp"}]}], ",", "Hp"}], 
           "}"}], "]"}]}], "]"}], ";", 
       RowBox[{"Hp", "=", "Ht"}]}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"result", " ", "to", " ", "compare"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Pd", "=", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0.664446", ",", "14933"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
