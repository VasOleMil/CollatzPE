           RowBox[{"Pp", "=", 
            RowBox[{"N", "[", 
             RowBox[{"Hr", "/", 
              RowBox[{"(", 
               RowBox[{"Pmax", "-", "Pmin"}], ")"}]}], "]"}]}], ",", "Hm"}], 
          "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Hm", "=", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{"0", ",", "Hr"}], "]"}]}], ";", 
          RowBox[{"Cs", "=", 
           RowBox[{"{", 
            RowBox[{"0", ",", "0"}], "}"}]}], ";", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"i", "=", "1"}], ",", 
            RowBox[{"i", "<=", "Tn"}], ",", 
            RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Cs", "=", 
              RowBox[{"ColStepP", "[", 
               RowBox[{"RandomInteger", "[", 
                RowBox[{"{", 
                 RowBox[{
