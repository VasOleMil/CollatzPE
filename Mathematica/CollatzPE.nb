          ";", "res"}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "calculate", " ", "hystogram", " ", "for", " ", "probability", " ", 
     "data"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ClearAll", "[", "ColHystc", "]"}], ";", 
    RowBox[{"ColHystc", "=", 
