       RowBox[{
        RowBox[{"j", "=", 
         RowBox[{"i", "+", "1"}]}], ",", 
        RowBox[{"j", "\[LessEqual]", "  ", "Pn"}], ",", 
        RowBox[{"j", "++"}], ",", 
        RowBox[{"T", "+=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Pd", "[", 
             RowBox[{"[", 
