   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", " ", "Hr"}], ",", 
      RowBox[{"i", "++"}], ",", " ", 
      RowBox[{
       RowBox[{"Ht", "=", 
        RowBox[{"Hv", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], ";", 
       RowBox[{"If", "[", 
