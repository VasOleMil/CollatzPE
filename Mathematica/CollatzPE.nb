                "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"3", "*", "nxt"}], "+", "1"}]}], "]"}]}]}]}], "]"}], 
          ";", 
          RowBox[{"{", 
           RowBox[{"s", ",", "e"}], "}"}]}]}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
