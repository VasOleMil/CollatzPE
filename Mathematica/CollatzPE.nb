         RowBox[{
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{"nxt", "!=", "1"}], ",", 
            RowBox[{
             RowBox[{"s", "++"}], ";", 
             RowBox[{"nxt", "=", 
              RowBox[{"If", "[", 
